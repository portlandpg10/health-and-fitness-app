# Server
PORT=3000
NODE_ENV=development

# Database (SQLite file path, relative to server directory)
DATABASE_PATH=./data/health.db

# Auth - set AUTH_PIN to enable PIN protection (4-8 digits, will be hashed)
# If not set, no auth is required (for trusted LAN)
AUTH_PIN=

# LLM API - for Workout Creator (Anthropic Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
